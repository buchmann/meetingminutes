# local-ai Configuration
# Copy this to .env and fill in your values

# Whisper transcription model (tiny, base, small, medium, large-v3)
LOCAL_AI_WHISPER_MODEL=large-v3
LOCAL_AI_WHISPER_COMPUTE_TYPE=int8

# Language: "auto", "en", or "de"
LOCAL_AI_LANGUAGE=auto

# Speaker diarization (requires HuggingFace token)
LOCAL_AI_DIARIZATION_ENABLED=true
LOCAL_AI_HF_TOKEN=hf_your_token_here
# Device for diarization: "cpu" (recommended on macOS), "cuda" (Linux/Windows GPU), "auto"
LOCAL_AI_DIARIZATION_DEVICE=cpu

# Ollama LLM summarization
LOCAL_AI_OLLAMA_BASE_URL=http://localhost:11434
LOCAL_AI_OLLAMA_MODEL=llama3.1:70b
LOCAL_AI_SUMMARIZATION_ENABLED=true

# Server
LOCAL_AI_HOST=127.0.0.1
LOCAL_AI_PORT=8000
LOCAL_AI_MAX_UPLOAD_SIZE_MB=500

# ── Multi-user / authentication ──────────────────────────────────────
# An initial admin is created on first startup when no users exist yet.
# Set a strong password, then create other users from the in-app admin
# page (/admin/users). Leave the password blank to skip seeding.
LOCAL_AI_ADMIN_USERNAME=admin
LOCAL_AI_ADMIN_PASSWORD=change-me
# Session cookie lifetime in hours (default 720 = 30 days)
LOCAL_AI_SESSION_TTL_HOURS=720
# Set true when serving over HTTPS so the session cookie is marked Secure
LOCAL_AI_SESSION_COOKIE_SECURE=false
