# Transkriptor Configuration
# Copy this to .env and fill in your values

# Whisper transcription model (tiny, base, small, medium, large-v3)
TRANSKRIPTOR_WHISPER_MODEL=large-v3
TRANSKRIPTOR_WHISPER_COMPUTE_TYPE=int8

# Language: "auto", "en", or "de"
TRANSKRIPTOR_LANGUAGE=auto

# Speaker diarization (requires HuggingFace token)
TRANSKRIPTOR_DIARIZATION_ENABLED=true
TRANSKRIPTOR_HF_TOKEN=hf_your_token_here
# Device for diarization: "cpu" (recommended on macOS), "cuda" (Linux/Windows GPU), "auto"
TRANSKRIPTOR_DIARIZATION_DEVICE=cpu

# Ollama LLM summarization
TRANSKRIPTOR_OLLAMA_BASE_URL=http://localhost:11434
TRANSKRIPTOR_OLLAMA_MODEL=llama3.1:70b
TRANSKRIPTOR_SUMMARIZATION_ENABLED=true

# Server
TRANSKRIPTOR_HOST=127.0.0.1
TRANSKRIPTOR_PORT=8000
TRANSKRIPTOR_MAX_UPLOAD_SIZE_MB=500

# ── Multi-user / authentication ──────────────────────────────────────
# An initial admin is created on first startup when no users exist yet.
# Set a strong password, then create other users from the in-app admin
# page (/admin/users). Leave the password blank to skip seeding.
TRANSKRIPTOR_ADMIN_USERNAME=admin
TRANSKRIPTOR_ADMIN_PASSWORD=change-me
# Session cookie lifetime in hours (default 720 = 30 days)
TRANSKRIPTOR_SESSION_TTL_HOURS=720
# Set true when serving over HTTPS so the session cookie is marked Secure
TRANSKRIPTOR_SESSION_COOKIE_SECURE=false
